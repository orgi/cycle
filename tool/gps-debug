#!/usr/bin/env bash
# Diagnostic: why don't emulator GPS fixes reach the app? Boots once, reuses the
# existing debug APK, enables location, sends fixes, and dumps state + logcat.
set -euo pipefail
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${CYCLE_DEV_IMAGE:-cycle-flutter-dev}"
DOCKER_ARGS=()
[[ -e /dev/kvm ]] && DOCKER_ARGS+=(--device=/dev/kvm --group-add=keep-groups)

exec docker run --rm "${DOCKER_ARGS[@]}" \
  -v "${REPO}:/work" -w /work \
  -e PUB_CACHE=/work/.cache/pub -e HOME=/work/.cache/home \
  "${IMAGE}" bash -lc '
    set -euo pipefail
    APP_ID=com.cycleapp.cycle
    export ANDROID_AVD_HOME=/tmp/avd; rm -rf "$ANDROID_AVD_HOME"; mkdir -p "$ANDROID_AVD_HOME"
    echo "no" | avdmanager create avd --force -n cycle_test -k "system-images;android-34;google_apis;x86_64" >/dev/null
    adb start-server >/dev/null 2>&1 || true
    echo ">> booting…"
    nohup emulator -avd cycle_test -no-window -no-audio -no-boot-anim -no-snapshot -read-only -gpu swiftshader_indirect -accel on > /tmp/emulator.log 2>&1 &
    adb wait-for-device
    until [ "$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d "\r")" = "1" ]; do sleep 2; done

    adb shell cmd location set-location-enabled true || true
    adb shell settings put secure location_mode 3 || true

    if [ ! -f build/app/outputs/flutter-apk/app-debug.apk ]; then echo ">> building…"; flutter build apk --debug >/dev/null; fi
    adb install -r build/app/outputs/flutter-apk/app-debug.apk >/dev/null
    adb shell pm grant "$APP_ID" android.permission.ACCESS_FINE_LOCATION || true
    adb shell pm grant "$APP_ID" android.permission.ACCESS_COARSE_LOCATION || true

    adb logcat -c || true
    adb emu geo fix 7.4246 43.7384 >/dev/null 2>&1 || true
    adb shell am start -n "$APP_ID/.MainActivity" >/dev/null
    sleep 4
    for i in 1 2 3 4 5; do adb emu geo fix "$(awk "BEGIN{printf \"%.6f\",7.4246+$i*0.0001}")" 43.7384 >/dev/null 2>&1 || true; sleep 1; done

    sleep 2
    OUT=screenshots/gps-debug.txt
    set +e   # diagnostics should never abort on a no-match grep
    {
      echo "=== location_mode ==="; adb shell settings get secure location_mode
      echo "=== perms ==="; adb shell dumpsys package "$APP_ID" | grep -i "location" | head
      echo "=== gps/fused provider requests (look for $APP_ID) ==="; adb shell dumpsys location | grep -iE "provider|cycle|WorkSource|ProviderRequest" | head -40
      echo "=== app [cycle] debug logs ==="; adb logcat -d | grep -F "[cycle]" | tail -40
      echo "=== FlutterGeolocator (full) ==="; adb logcat -d -s FlutterGeolocator | tail -50
      echo "=== geolocator/location any ==="; adb logcat -d | grep -iE "geolocator|geolocation|locationmanager|requestlocation" | tail -40
      echo "=== crashes / runtime errors ==="; adb logcat -d | grep -iE "AndroidRuntime|FATAL|MissingPlugin|Unhandled" | tail -30
    } > "$OUT" 2>&1
    echo ">> wrote $OUT"
    echo ">> done"
  '
