#!/usr/bin/env bash
# Build, boot the emulator, launch the app and screenshot it after it has had
# time to render — to confirm the standalone app gets past the splash.
set -euo pipefail
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${CYCLE_DEV_IMAGE:-cycle-flutter-dev}"
DOCKER_ARGS=()
[[ -e /dev/kvm ]] && DOCKER_ARGS+=(--device=/dev/kvm --group-add=keep-groups)
mkdir -p "${REPO}/screenshots"

exec docker run --rm "${DOCKER_ARGS[@]}" \
  -v "${REPO}:/work" -w /work \
  -e PUB_CACHE=/work/.cache/pub -e HOME=/work/.cache/home \
  "${IMAGE}" bash -lc '
    set -euo pipefail
    APP_ID=com.cycleapp.cycle
    export ANDROID_AVD_HOME=/tmp/avd; rm -rf "$ANDROID_AVD_HOME"; mkdir -p "$ANDROID_AVD_HOME"
    echo "no" | avdmanager create avd --force -n cycle_test -k "system-images;android-34;google_apis;x86_64" >/dev/null
    adb start-server >/dev/null 2>&1 || true
    echo ">> booting…"
    nohup emulator -avd cycle_test -no-window -no-audio -no-boot-anim -no-snapshot -read-only -gpu swiftshader_indirect -accel on > /tmp/emulator.log 2>&1 &
    adb wait-for-device
    until [ "$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d "\r")" = "1" ]; do sleep 2; done
    adb shell cmd location set-location-enabled true || true; adb shell settings put secure location_mode 3 || true

    echo ">> building…"; flutter build apk --debug >/dev/null
    adb install -r build/app/outputs/flutter-apk/app-debug.apk >/dev/null
    adb shell pm grant "$APP_ID" android.permission.ACCESS_FINE_LOCATION || true
    adb emu geo fix 7.4262 43.7399 >/dev/null 2>&1 || true
    adb shell am start -n "$APP_ID/.MainActivity" >/dev/null
    echo ">> waiting 25s for render…"; sleep 25
    adb exec-out screencap -p > screenshots/launch_check.png
    echo ">> wrote screenshots/launch_check.png"; echo ">> done"
  '
