#!/usr/bin/env bash
# Record a full recording session: Start → trip-computer metrics climbing →
# switch to the map (marker moving through Monaco) → Stop → ride saved in Rides.
# Output: videos/recording_session.mp4
set -euo pipefail
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${CYCLE_DEV_IMAGE:-cycle-flutter-dev}"
DOCKER_ARGS=()
[[ -e /dev/kvm ]] && DOCKER_ARGS+=(--device=/dev/kvm --group-add=keep-groups)
mkdir -p "${REPO}/videos"

exec docker run --rm "${DOCKER_ARGS[@]}" \
  -v "${REPO}:/work" -w /work \
  -e PUB_CACHE=/work/.cache/pub -e HOME=/work/.cache/home \
  "${IMAGE}" bash -lc '
    set -euo pipefail
    APP_ID=com.cycleapp.cycle
    export ANDROID_AVD_HOME=/tmp/avd; rm -rf "$ANDROID_AVD_HOME"; mkdir -p "$ANDROID_AVD_HOME"
    echo "no" | avdmanager create avd --force -n cycle_test -k "system-images;android-34;google_apis;x86_64" >/dev/null
    adb start-server >/dev/null 2>&1 || true
    echo ">> booting…"
    nohup emulator -avd cycle_test -no-window -no-audio -no-boot-anim -no-snapshot -read-only -gpu swiftshader_indirect -accel on > /tmp/emulator.log 2>&1 &
    adb wait-for-device
    until [ "$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d "\r")" = "1" ]; do sleep 2; done
    adb shell cmd location set-location-enabled true || true
    adb shell settings put secure location_mode 3 || true

    if [ ! -f build/app/outputs/flutter-apk/app-debug.apk ]; then echo ">> building…"; flutter build apk --debug >/dev/null; fi
    adb install -r build/app/outputs/flutter-apk/app-debug.apk >/dev/null
    adb shell pm grant "$APP_ID" android.permission.ACCESS_FINE_LOCATION || true
    adb shell pm grant "$APP_ID" android.permission.ACCESS_COARSE_LOCATION || true
    adb shell pm grant "$APP_ID" android.permission.POST_NOTIFICATIONS || true

    LAT0=43.7384; LON0=7.4246; STEP=0.00008
    fix() { LON=$(awk "BEGIN{printf \"%.6f\", $LON0 + $1*$STEP}"); LAT=$(awk "BEGIN{printf \"%.6f\", $LAT0 + $1*0.00002}"); adb emu geo fix "$LON" "$LAT" >/dev/null 2>&1 || true; }

    fix 0
    echo ">> recording…"
    adb shell screenrecord --time-limit 170 --bit-rate 6000000 /sdcard/cycle.mp4 &
    SR=$!
    sleep 1
    adb shell am start -n "$APP_ID/.MainActivity" >/dev/null
    sleep 12  # M4 build cold-starts slowly on the software-rendered emulator

    read W H < <(adb shell wm size | grep -o "[0-9]*x[0-9]*" | tr "x" " ")
    DENS=$(adb shell wm density | grep -o "[0-9]*" | head -1)
    dp() { echo $(( $1 * DENS / 160 )); }
    APPBAR_Y=$(dp 56)
    MAP_X=$(( W - $(dp 24) ))          # rightmost app-bar action
    TRACKS_X=$(( W - $(dp 120) ))      # leftmost of the three app-bar actions
    FAB_X=$(( W / 2 )); FAB_Y=$(( H - $(dp 40) ))
    echo ">> ${W}x${H} d${DENS}: fab=$FAB_X,$FAB_Y map=$MAP_X,$APPBAR_Y tracks=$TRACKS_X,$APPBAR_Y"

    echo ">> START recording"
    adb shell input tap "$FAB_X" "$FAB_Y"; sleep 2

    echo ">> trip-computer phase"
    for i in $(seq 1 18); do fix "$i"; sleep 1; done

    echo ">> map phase"
    adb shell input tap "$MAP_X" "$APPBAR_Y"; sleep 4
    for i in $(seq 19 46); do fix "$i"; sleep 1; done
    adb shell input keyevent KEYCODE_BACK; sleep 2   # back to dashboard

    echo ">> more trip-computer"
    for i in $(seq 47 56); do fix "$i"; sleep 1; done

    echo ">> STOP recording"
    adb shell input tap "$FAB_X" "$FAB_Y"; sleep 2

    echo ">> open Rides"
    adb shell input tap "$TRACKS_X" "$APPBAR_Y"; sleep 3

    echo ">> finishing"
    adb shell pkill -INT screenrecord || true
    wait "$SR" 2>/dev/null || true
    sleep 2
    adb pull /sdcard/cycle.mp4 videos/recording_session.mp4 >/dev/null
    echo ">> wrote videos/recording_session.mp4"
    echo ">> done"
  '
