#!/usr/bin/env bash
# Fast single-ABI build (arm64-v8a — the Galaxy A33 / modern phones) + in-place
# install on the connected device.
#
#   tool/build            # debug build (fast, no AOT) -> adb install -r
#   tool/build --release  # release-signed build       -> adb install -r
#
# Debug builds are much faster than release and the debug key is stable, so
# `adb install -r` updates in place (downloaded maps survive). Switching the
# installed app between debug- and release-signed needs a one-time
# `adb uninstall com.cycleapp.cycle`.
set -euo pipefail
cd "$(dirname "${BASH_SOURCE[0]}")/.."

MODE=debug
[[ "${1:-}" == "--release" ]] && MODE=release

echo ">> building $MODE arm64 APK (single ABI)…"
tool/fl flutter build apk --"$MODE" --target-platform android-arm64

APK="build/app/outputs/flutter-apk/app-$MODE.apk"
[[ -f "$APK" ]] || { echo "APK not found at $APK"; exit 1; }
echo ">> adb install -r $APK"
adb install -r "$APK"
echo ">> done ($MODE)"
