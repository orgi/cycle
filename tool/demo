#!/usr/bin/env bash
# Full demo capture: records a video AND grabs screenshots of the current app —
# dashboard, the combined map (map box + metric boxes), and Rides.
# Output: videos/demo.mp4 + screenshots/shot_*.png
set -euo pipefail
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${CYCLE_DEV_IMAGE:-cycle-flutter-dev}"
DOCKER_ARGS=()
[[ -e /dev/kvm ]] && DOCKER_ARGS+=(--device=/dev/kvm --group-add=keep-groups)
mkdir -p "${REPO}/screenshots" "${REPO}/videos"

exec docker run --rm "${DOCKER_ARGS[@]}" \
  -v "${REPO}:/work" -w /work \
  -e PUB_CACHE=/work/.cache/pub -e HOME=/work/.cache/home \
  "${IMAGE}" bash -lc '
    set -euo pipefail
    APP_ID=com.cycleapp.cycle
    export ANDROID_AVD_HOME=/tmp/avd; rm -rf "$ANDROID_AVD_HOME"; mkdir -p "$ANDROID_AVD_HOME"
    echo "no" | avdmanager create avd --force -n cycle_test -k "system-images;android-34;google_apis;x86_64" >/dev/null
    adb start-server >/dev/null 2>&1 || true
    echo ">> booting…"
    nohup emulator -avd cycle_test -no-window -no-audio -no-boot-anim -no-snapshot -read-only -gpu swiftshader_indirect -accel on > /tmp/emulator.log 2>&1 &
    adb wait-for-device
    until [ "$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d "\r")" = "1" ]; do sleep 2; done
    adb shell cmd location set-location-enabled true || true; adb shell settings put secure location_mode 3 || true

    echo ">> building…"; flutter build apk --debug >/dev/null
    adb install -r build/app/outputs/flutter-apk/app-debug.apk >/dev/null
    adb shell pm grant "$APP_ID" android.permission.ACCESS_FINE_LOCATION || true

    # Replay a real Monaco-circuit route (follows actual streets). File has
    # "lon lat" per line.
    mapfile -t ROUTE < tool/routes/monaco_loop.txt
    IDX=0
    next_fix() { set -- ${ROUTE[$IDX]}; adb emu geo fix "$1" "$2" >/dev/null 2>&1 || true; IDX=$(( (IDX+1) % ${#ROUTE[@]} )); }

    next_fix
    echo ">> recording…"
    adb shell screenrecord --time-limit 170 --bit-rate 6000000 /sdcard/demo.mp4 &
    SR=$!
    sleep 1
    adb shell am start -n "$APP_ID/.MainActivity" >/dev/null
    echo ">> waiting for render…"; sleep 20

    read W H < <(adb shell wm size | grep -o "[0-9]*x[0-9]*" | tr "x" " ")
    DENS=$(adb shell wm density | grep -o "[0-9]*" | head -1)
    dp() { echo $(( $1 * DENS / 160 )); }
    APPBAR_Y=$(dp 56)
    MAP_X=$(( W - $(dp 24) ))
    TRACKS_X=$(( W - $(dp 120) ))
    FOLLOW_X=$(( W - $(dp 168) ))   # leftmost app-bar action (follow-route menu)
    BTN_X=$(( W / 2 )); BTN_Y=$(( H - $(dp 34) ))
    cap() { adb exec-out screencap -p > "screenshots/$1.png"; echo "   $1"; }

    # Open the follow-route menu and tap "Follow demo route" — robustly, by
    # reading the popup item bounds from a uiautomator dump (no guessed coords).
    # NB: this whole script runs inside bash -lc "..." (single-quoted by docker),
    # so use double quotes only — no nested single quotes.
    load_demo_route() {
      adb shell input tap "$FOLLOW_X" "$APPBAR_Y"; sleep 1
      adb shell uiautomator dump /sdcard/ui.xml >/dev/null 2>&1 || true
      # One node per line, keep the one with the menu label, pull its bounds.
      local nums; nums="$( { adb shell cat /sdcard/ui.xml 2>/dev/null \
        | tr ">" "\n" \
        | grep "Follow demo route" \
        | grep -oE "bounds=\"\[[0-9]+,[0-9]+\]\[[0-9]+,[0-9]+\]\"" \
        | head -1 | grep -oE "[0-9]+" | tr "\n" " "; } || true)"
      if [ -n "$nums" ]; then
        set -- $nums
        adb shell input tap $(( ($1 + $3) / 2 )) $(( ($2 + $4) / 2 ))
      else
        echo "   (could not locate route menu item)"
      fi
      sleep 2
    }

    # Home is the combined map + stats screen.
    cap shot_1_home
    echo ">> follow demo route"; load_demo_route; cap shot_1a_route
    echo ">> start recording"; adb shell input tap "$BTN_X" "$BTN_Y"; sleep 2
    # ~10 m between route points; 1.1 s each ≈ 33 km/h (realistic).
    for i in $(seq 1 7); do next_fix; sleep 1.1; done
    cap shot_1b_start   # early — does the map follow from the start?
    for i in $(seq 1 38); do next_fix; sleep 1.1; done
    cap shot_2_riding
    for i in $(seq 1 45); do next_fix; sleep 1.1; done
    cap shot_3_riding_more

    echo ">> stop + rides"
    adb shell input tap "$BTN_X" "$BTN_Y"; sleep 2   # stop
    adb shell input tap "$TRACKS_X" "$APPBAR_Y"; sleep 3
    cap shot_4_rides

    # Rides app bar -> "Upload accounts" (cloud icon, the only action = rightmost).
    echo ">> upload accounts settings"
    adb shell input tap "$MAP_X" "$APPBAR_Y"; sleep 2
    cap shot_6_upload_settings

    echo ">> finishing"
    adb shell pkill -INT screenrecord || true
    wait "$SR" 2>/dev/null || true
    sleep 2
    adb pull /sdcard/demo.mp4 videos/demo.mp4 >/dev/null
    echo ">> wrote videos/demo.mp4 + screenshots"

    # Best-effort "Open .gpx with Cycle" test, fully fault-isolated (set +e in a
    # subshell) so it can never break the rest of the demo. The gpx is placed in
    # the app'\''s OWN internal storage via run-as: adb-pushing to
    # /sdcard/Android/data is invisible to the app (separate FUSE views on API
    # 30+), and a real file manager hands over a content:// URI — both reach the
    # same contentResolver.openInputStream() path in MainActivity.
    ( set +e
      INT="/data/data/$APP_ID/files/imported_ride.gpx"
      echo ">> open a .gpx via VIEW intent"
      adb push assets/routes/monaco_loop.gpx /sdcard/Download/imported_ride.gpx >/dev/null 2>&1
      adb shell "run-as $APP_ID mkdir -p /data/data/$APP_ID/files" 2>/dev/null
      adb shell "cat /sdcard/Download/imported_ride.gpx | run-as $APP_ID tee $INT >/dev/null" 2>/dev/null
      echo "   placed file bytes: [$(adb shell run-as $APP_ID wc -c $INT 2>/dev/null)]"
      adb shell am force-stop "$APP_ID"
      adb logcat -c
      adb shell am start -a android.intent.action.VIEW -d "file://$INT" \
        -t application/gpx+xml -n "$APP_ID/.MainActivity" >/dev/null 2>&1
      sleep 12
      adb exec-out screencap -p > "screenshots/shot_5_opened_gpx.png"; echo "   shot_5_opened_gpx"
      echo ">> CycleGpx logs:"; adb logcat -d -s CycleGpx:* | tail -10
      echo ">> gpx VIEW filters:"; adb shell dumpsys package "$APP_ID" | grep -iC1 gpx | head -8
    ) 2>&1 || true

    echo ">> done"
  '
