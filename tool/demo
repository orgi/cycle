#!/usr/bin/env bash
# Full demo capture: records a video AND grabs screenshots of the current app —
# dashboard, the combined map (map box + metric boxes), and Rides.
# Output: videos/demo.mp4 + screenshots/shot_*.png
set -euo pipefail
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
IMAGE="${CYCLE_DEV_IMAGE:-cycle-flutter-dev}"
DOCKER_ARGS=()
[[ -e /dev/kvm ]] && DOCKER_ARGS+=(--device=/dev/kvm --group-add=keep-groups)
mkdir -p "${REPO}/screenshots" "${REPO}/videos"

exec docker run --rm "${DOCKER_ARGS[@]}" \
  -v "${REPO}:/work" -w /work \
  -e PUB_CACHE=/work/.cache/pub -e HOME=/work/.cache/home \
  "${IMAGE}" bash -lc '
    set -euo pipefail
    APP_ID=com.cycleapp.cycle
    export ANDROID_AVD_HOME=/tmp/avd; rm -rf "$ANDROID_AVD_HOME"; mkdir -p "$ANDROID_AVD_HOME"
    echo "no" | avdmanager create avd --force -n cycle_test -k "system-images;android-34;google_apis;x86_64" >/dev/null
    adb start-server >/dev/null 2>&1 || true
    echo ">> booting…"
    nohup emulator -avd cycle_test -no-window -no-audio -no-boot-anim -no-snapshot -read-only -gpu swiftshader_indirect -accel on > /tmp/emulator.log 2>&1 &
    adb wait-for-device
    until [ "$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d "\r")" = "1" ]; do sleep 2; done
    adb shell cmd location set-location-enabled true || true; adb shell settings put secure location_mode 3 || true

    echo ">> building…"; flutter build apk --debug >/dev/null
    adb install -r build/app/outputs/flutter-apk/app-debug.apk >/dev/null
    adb shell pm grant "$APP_ID" android.permission.ACCESS_FINE_LOCATION || true

    # Replay a real Monaco-circuit route (follows actual streets). File has
    # "lon lat" per line.
    mapfile -t ROUTE < tool/routes/monaco_loop.txt
    IDX=0
    next_fix() { set -- ${ROUTE[$IDX]}; adb emu geo fix "$1" "$2" >/dev/null 2>&1 || true; IDX=$(( (IDX+1) % ${#ROUTE[@]} )); }

    next_fix
    echo ">> recording…"
    adb shell screenrecord --time-limit 170 --bit-rate 6000000 /sdcard/demo.mp4 &
    SR=$!
    sleep 1
    adb shell am start -n "$APP_ID/.MainActivity" >/dev/null
    echo ">> waiting for render…"; sleep 20

    read W H < <(adb shell wm size | grep -o "[0-9]*x[0-9]*" | tr "x" " ")
    DENS=$(adb shell wm density | grep -o "[0-9]*" | head -1)
    dp() { echo $(( $1 * DENS / 160 )); }
    APPBAR_Y=$(dp 56)
    # Map app-bar actions, right-aligned (centres at 24,72,120,168,216 dp from
    # the right): settings, maps, sensors, tracks, follow.
    MAP_X=$(( W - $(dp 24) ))        # rightmost app-bar action
    SETTINGS_X=$(( W - $(dp 24) ))   # settings (rightmost on the map screen)
    MAPS_X=$(( W - $(dp 72) ))       # manage maps (layers, 2nd from right)
    TRACKS_X=$(( W - $(dp 168) ))    # Rides (history)
    FOLLOW_X=$(( W - $(dp 216) ))    # leftmost action (follow-route menu)
    BTN_X=$(( W / 2 )); BTN_Y=$(( H - $(dp 34) ))
    cap() { adb exec-out screencap -p > "screenshots/$1.png"; echo "   $1"; }

    # Open the follow-route menu and tap "Follow demo route" — robustly, by
    # reading the popup item bounds from a uiautomator dump (no guessed coords).
    # NB: this whole script runs inside bash -lc "..." (single-quoted by docker),
    # so use double quotes only — no nested single quotes.
    load_demo_route() {
      adb shell input tap "$FOLLOW_X" "$APPBAR_Y"; sleep 1
      adb shell uiautomator dump /sdcard/ui.xml >/dev/null 2>&1 || true
      # One node per line, keep the one with the menu label, pull its bounds.
      local nums; nums="$( { adb shell cat /sdcard/ui.xml 2>/dev/null \
        | tr ">" "\n" \
        | grep "Follow demo route" \
        | grep -oE "bounds=\"\[[0-9]+,[0-9]+\]\[[0-9]+,[0-9]+\]\"" \
        | head -1 | grep -oE "[0-9]+" | tr "\n" " "; } || true)"
      if [ -n "$nums" ]; then
        set -- $nums
        adb shell input tap $(( ($1 + $3) / 2 )) $(( ($2 + $4) / 2 ))
      else
        echo "   (could not locate route menu item)"
      fi
      sleep 2
    }

    # Home is the combined map + stats screen.
    cap shot_1_home
    echo ">> follow demo route"; load_demo_route; cap shot_1a_route
    echo ">> start recording"; adb shell input tap "$BTN_X" "$BTN_Y"; sleep 2
    # ~10 m between route points; 1.1 s each ≈ 33 km/h (realistic).
    for i in $(seq 1 7); do next_fix; sleep 1.1; done
    cap shot_1b_start   # early — does the map follow from the start?
    for i in $(seq 1 38); do next_fix; sleep 1.1; done
    cap shot_2_riding
    for i in $(seq 1 45); do next_fix; sleep 1.1; done
    cap shot_3_riding_more

    echo ">> stop + rides"
    adb shell input tap "$BTN_X" "$BTN_Y"; sleep 2   # stop
    adb shell input tap "$TRACKS_X" "$APPBAR_Y"; sleep 3
    cap shot_4_rides

    # Rides app bar -> "Upload accounts" (cloud icon, the only action = rightmost).
    echo ">> upload accounts settings"
    adb shell input tap "$MAP_X" "$APPBAR_Y"; sleep 2
    cap shot_6_upload_settings

    echo ">> finishing"
    adb shell pkill -INT screenrecord || true
    wait "$SR" 2>/dev/null || true
    sleep 2
    adb pull /sdcard/demo.mp4 videos/demo.mp4 >/dev/null
    echo ">> wrote videos/demo.mp4 + screenshots"

    # Best-effort "Open .gpx with Cycle" test, fully fault-isolated (set +e in a
    # subshell) so it can never break the rest of the demo. The gpx is placed in
    # the app'\''s OWN internal storage via run-as: adb-pushing to
    # /sdcard/Android/data is invisible to the app (separate FUSE views on API
    # 30+), and a real file manager hands over a content:// URI — both reach the
    # same contentResolver.openInputStream() path in MainActivity.
    ( set +e
      INT="/data/data/$APP_ID/files/imported_ride.gpx"
      echo ">> open a .gpx via VIEW intent"
      adb push assets/routes/monaco_loop.gpx /sdcard/Download/imported_ride.gpx >/dev/null 2>&1
      adb shell "run-as $APP_ID mkdir -p /data/data/$APP_ID/files" 2>/dev/null
      adb shell "cat /sdcard/Download/imported_ride.gpx | run-as $APP_ID tee $INT >/dev/null" 2>/dev/null
      echo "   placed file bytes: [$(adb shell run-as $APP_ID wc -c $INT 2>/dev/null)]"
      adb shell am force-stop "$APP_ID"
      adb logcat -c
      adb shell am start -a android.intent.action.VIEW -d "file://$INT" \
        -t application/gpx+xml -n "$APP_ID/.MainActivity" >/dev/null 2>&1
      sleep 12
      adb exec-out screencap -p > "screenshots/shot_5_opened_gpx.png"; echo "   shot_5_opened_gpx"
      echo ">> CycleGpx logs:"; adb logcat -d -s CycleGpx:* | tail -10
      echo ">> gpx VIEW filters:"; adb shell dumpsys package "$APP_ID" | grep -iC1 gpx | head -8
    ) 2>&1 || true

    # Volume-key start/stop + Settings, fault-isolated. Relaunch fresh, then
    # inject the hardware volume keys and confirm they toggle recording.
    ( set +e
      echo ">> volume-key start/stop test"
      adb shell am force-stop "$APP_ID"
      adb shell am start -n "$APP_ID/.MainActivity" >/dev/null 2>&1
      sleep 10
      adb logcat -c
      # Baseline media volume; it must NOT change when we press the keys.
      VOL0=$(adb shell cmd media_session volume --stream 3 --get 2>/dev/null | grep -oE "volume is [0-9]+" | grep -oE "[0-9]+" | head -1)
      adb exec-out screencap -p > "screenshots/shot_7_home_idle.png"; echo "   shot_7_home_idle (vol=$VOL0)"
      adb shell input keyevent KEYCODE_VOLUME_UP   # start recording
      sleep 3
      adb exec-out screencap -p > "screenshots/shot_8_volkey_recording.png"; echo "   shot_8_volkey_recording"
      adb shell input keyevent KEYCODE_VOLUME_DOWN # stop recording
      sleep 2
      adb exec-out screencap -p > "screenshots/shot_9_volkey_stopped.png"; echo "   shot_9_volkey_stopped"
      VOL1=$(adb shell cmd media_session volume --stream 3 --get 2>/dev/null | grep -oE "volume is [0-9]+" | grep -oE "[0-9]+" | head -1)
      echo "   media volume: before=$VOL0 after=$VOL1 (should be equal = keys intercepted)"
      echo ">> volume-key native logs:"; adb logcat -d -s CycleGpx:* | grep -i "volume key" | tail -6
      # Settings screen (rightmost app-bar action).
      adb shell input tap "$SETTINGS_X" "$APPBAR_Y"; sleep 2
      adb exec-out screencap -p > "screenshots/shot_10_settings.png"; echo "   shot_10_settings"
    ) 2>&1 || true

    # Map manager: storage location, then a real OpenAndroMaps download
    # (Andorra, ~27 MB) to exercise the streaming download + zip-extract end to
    # end on a real file. Fault-isolated.
    ( set +e
      echo ">> manage maps + real download test"
      adb shell am force-stop "$APP_ID"
      adb shell am start -n "$APP_ID/.MainActivity" >/dev/null 2>&1
      sleep 9
      adb shell input tap "$MAPS_X" "$APPBAR_Y"; sleep 2
      adb exec-out screencap -p > "screenshots/shot_11_manage_maps.png"; echo "   shot_11_manage_maps"
      # The catalogue now has ~80 regions in groups (Regions / Countries /
      # Germany). Andorra (small, ~27 MB) is in Countries, below the fold —
      # scroll until it is on screen before locating its row.
      for s in $(seq 1 8); do
        adb shell uiautomator dump /sdcard/ui.xml >/dev/null 2>&1
        if adb shell cat /sdcard/ui.xml 2>/dev/null | grep -q "Andorra"; then break; fi
        adb shell input swipe $(( W / 2 )) $(( H * 3 / 4 )) $(( W / 2 )) $(( H / 4 )) 250
        sleep 1
      done
      # Locate the Andorra row and tap its trailing download icon (far right).
      AY="$( { adb shell cat /sdcard/ui.xml 2>/dev/null | tr ">" "\n" \
        | grep "Andorra" | grep -oE "bounds=\"\[[0-9]+,[0-9]+\]\[[0-9]+,[0-9]+\]\"" \
        | head -1 | grep -oE "[0-9]+" | tr "\n" " "; } || true)"
      if [ -n "$AY" ]; then
        set -- $AY; CY=$(( ($2 + $4) / 2 ))
        adb shell input tap $(( W - $(dp 28) )) "$CY"   # download icon
        echo "   tapped download for Andorra at y=$CY"
        for i in $(seq 1 12); do sleep 8; done          # up to ~96s
        adb exec-out screencap -p > "screenshots/shot_12_download.png"; echo "   shot_12_download"
        echo ">> installed .map files on device:"
        adb shell "run-as $APP_ID find /data/data/$APP_ID -name *.map 2>/dev/null; find /sdcard/Android/data/$APP_ID -name *.map 2>/dev/null" | head
        # Back to the home map and move GPS INTO Andorra — the downloaded region
        # must now render (the bug was a camera parked over Monaco, outside it).
        adb shell input keyevent KEYCODE_BACK; sleep 2
        adb emu geo fix 1.601 42.546   # central Andorra (lon lat)
        sleep 10
        adb exec-out screencap -p > "screenshots/shot_13_andorra_map.png"; echo "   shot_13_andorra_map"
        # The reported symptom is "black on reopen" with NO GPS. Disable
        # location and relaunch: the map must still render, centred on the
        # downloaded region bounding box (not the Monaco demo location).
        adb shell settings put secure location_mode 0
        adb shell am force-stop "$APP_ID"
        adb shell am start -n "$APP_ID/.MainActivity" >/dev/null 2>&1
        sleep 12
        adb exec-out screencap -p > "screenshots/shot_14_reopen_nogps.png"; echo "   shot_14_reopen_nogps"
        adb shell settings put secure location_mode 3   # restore for later runs
        # Catalogue depth: open Manage maps and scroll to the Germany group to
        # show the Bundesland sub-regions (e.g. Bayern / Bavaria) are listed.
        adb shell input tap "$MAPS_X" "$APPBAR_Y"; sleep 2
        for s in $(seq 1 10); do
          adb shell uiautomator dump /sdcard/ui.xml >/dev/null 2>&1
          if adb shell cat /sdcard/ui.xml 2>/dev/null | grep -q "Bayern"; then break; fi
          adb shell input swipe $(( W / 2 )) $(( H * 3 / 4 )) $(( W / 2 )) $(( H / 4 )) 250
          sleep 1
        done
        adb exec-out screencap -p > "screenshots/shot_15_germany.png"; echo "   shot_15_germany (Bayern listed)"
      else
        echo "   (could not locate Andorra row)"
      fi
    ) 2>&1 || true

    echo ">> done"
  '
