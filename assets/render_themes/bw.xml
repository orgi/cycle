<?xml version="1.0" encoding="UTF-8"?>
<!--
  Black & white render theme for the Cycle bike computer.
  Dark base (OLED-friendly) but HIGH CONTRAST and fully grayscale: built-up
  areas read as mid-gray, buildings as lighter gray, water a distinct gray, and
  roads brighten with importance up to white. Zoom thresholds are deliberately
  low so there is always structure to see. No external symbol/pattern assets.
-->
<rendertheme xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://mapsforge.org/renderTheme"
    xsi:schemaLocation="http://mapsforge.org/renderTheme https://raw.githubusercontent.com/mapsforge/mapsforge/master/resources/renderTheme.xsd"
    version="5" map-background="#0A0A0A" map-background-outside="#000000">

    <!-- Water — a clearly distinct mid gray -->
    <rule e="way" k="natural" v="sea|issea|water">
        <area fill="#3C3C3C" />
    </rule>
    <rule e="way" k="landuse" v="reservoir|basin">
        <area fill="#3C3C3C" />
    </rule>
    <rule e="way" k="waterway" v="riverbank|dock">
        <area fill="#3C3C3C" />
    </rule>
    <rule e="way" k="waterway" v="river|canal">
        <line stroke="#4A4A4A" stroke-width="1.4" />
    </rule>
    <rule e="way" k="waterway" v="stream|ditch" zoom-min="13">
        <line stroke="#3A3A3A" stroke-width="0.7" />
    </rule>

    <!-- Green / natural areas -->
    <rule e="way" k="natural" v="wood">
        <area fill="#1C1C1C" />
    </rule>
    <rule e="way" k="landuse" v="forest|wood|grass|meadow|village_green">
        <area fill="#1C1C1C" />
    </rule>
    <rule e="way" k="leisure" v="park|garden|pitch|recreation_ground" zoom-min="12">
        <area fill="#242424" />
    </rule>

    <!-- Built-up areas read as a visible mid gray (not a black void) -->
    <rule e="way" k="landuse" v="residential|commercial|industrial|retail|construction" zoom-min="11">
        <area fill="#262626" />
    </rule>

    <!-- Buildings — lighter gray footprints with an outline -->
    <rule e="way" k="building" v="*" zoom-min="14">
        <area fill="#454545" stroke="#5A5A5A" stroke-width="0.3" />
    </rule>

    <!-- Railways -->
    <rule e="way" k="railway" v="rail" zoom-min="12">
        <line stroke="#7A7A7A" stroke-width="0.8" stroke-dasharray="6,3" />
    </rule>

    <!-- Roads, grayscale by importance (brighter + a touch thicker), minor → major -->
    <rule e="way" k="highway" v="service|living_street" zoom-min="14">
        <line stroke="#707070" stroke-width="1.0" />
    </rule>
    <rule e="way" k="highway" v="residential|unclassified|road" zoom-min="12">
        <line stroke="#9C9C9C" stroke-width="1.3" />
    </rule>
    <rule e="way" k="highway" v="tertiary|tertiary_link" zoom-min="11">
        <line stroke="#B8B8B8" stroke-width="1.5" />
    </rule>
    <rule e="way" k="highway" v="secondary|secondary_link" zoom-min="10">
        <line stroke="#CECECE" stroke-width="1.6" />
    </rule>
    <rule e="way" k="highway" v="primary|primary_link" zoom-min="8">
        <line stroke="#E2E2E2" stroke-width="1.8" />
    </rule>
    <rule e="way" k="highway" v="trunk|trunk_link" zoom-min="7">
        <line stroke="#F0F0F0" stroke-width="1.9" />
    </rule>
    <rule e="way" k="highway" v="motorway|motorway_link" zoom-min="6">
        <line stroke="#FFFFFF" stroke-width="2.1" />
    </rule>

    <!-- Cycling infrastructure — bright white, dashed to distinguish -->
    <rule e="way" k="highway" v="cycleway" zoom-min="12">
        <line stroke="#FFFFFF" stroke-width="1.3" stroke-dasharray="5,3" />
    </rule>
    <rule e="way" k="cycleway" v="track|lane|opposite_track|opposite_lane" zoom-min="13">
        <line stroke="#D6D6D6" stroke-width="1.0" stroke-dasharray="4,2" />
    </rule>
    <rule e="way" k="highway" v="path|footway|track|bridleway" zoom-min="13">
        <line stroke="#9A9A9A" stroke-width="0.8" stroke-dasharray="3,2" />
    </rule>

    <!-- Road name labels at high zoom -->
    <rule e="way" k="highway" v="motorway|trunk|primary|secondary|tertiary|residential" zoom-min="16">
        <caption k="name" font-style="bold" font-size="11" fill="#FFFFFF" stroke="#000000" stroke-width="2.5" />
    </rule>

    <!-- Place labels -->
    <rule e="node" k="place" v="city|town" zoom-min="8">
        <caption k="name" font-style="bold" font-size="13" fill="#FFFFFF" stroke="#000000" stroke-width="2.5" />
    </rule>
    <rule e="node" k="place" v="village|suburb" zoom-min="12">
        <caption k="name" font-size="11" fill="#E0E0E0" stroke="#000000" stroke-width="2.5" />
    </rule>
</rendertheme>
