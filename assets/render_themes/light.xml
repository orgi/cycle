<?xml version="1.0" encoding="UTF-8"?>
<!--
  Light render theme for the Cycle bike computer (daytime / preference).
  Conventional bright map: pale land, blue water, green parks, white-to-coloured
  roads with cycleways emphasised. No external symbol/pattern assets.
-->
<rendertheme xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="http://mapsforge.org/renderTheme"
    xsi:schemaLocation="http://mapsforge.org/renderTheme https://raw.githubusercontent.com/mapsforge/mapsforge/master/resources/renderTheme.xsd"
    version="5" map-background="#F4F2EC" map-background-outside="#E8E6E0">

    <!-- Water -->
    <rule e="way" k="natural" v="sea|issea|water">
        <area fill="#AAD3DF" />
    </rule>
    <rule e="way" k="landuse" v="reservoir|basin">
        <area fill="#AAD3DF" />
    </rule>
    <rule e="way" k="waterway" v="riverbank|dock">
        <area fill="#AAD3DF" />
    </rule>
    <rule e="way" k="waterway" v="river|canal">
        <line stroke="#9FC6D8" stroke-width="1.2" />
    </rule>
    <rule e="way" k="waterway" v="stream|ditch" zoom-min="14">
        <line stroke="#9FC6D8" stroke-width="0.6" />
    </rule>

    <!-- Green / natural areas -->
    <rule e="way" k="natural" v="wood">
        <area fill="#C8E0C0" />
    </rule>
    <rule e="way" k="landuse" v="forest|wood|grass|meadow|village_green">
        <area fill="#C8E0C0" />
    </rule>
    <rule e="way" k="leisure" v="park|garden|pitch|recreation_ground" zoom-min="13">
        <area fill="#D2ECCB" />
    </rule>
    <rule e="way" k="landuse" v="residential|commercial|industrial|retail" zoom-min="13">
        <area fill="#ECE9E2" />
    </rule>

    <!-- Buildings -->
    <rule e="way" k="building" v="*" zoom-min="15">
        <area fill="#E0D8CC" stroke="#CDC4B6" stroke-width="0.2" />
    </rule>

    <!-- Railways -->
    <rule e="way" k="railway" v="rail" zoom-min="12">
        <line stroke="#999999" stroke-width="0.7" stroke-dasharray="6,3" />
    </rule>

    <!-- Roads, drawn minor → major so majors paint on top -->
    <rule e="way" k="highway" v="service|living_street" zoom-min="14">
        <line stroke="#BDBDBD" stroke-width="0.8" />
    </rule>
    <rule e="way" k="highway" v="residential|unclassified|road" zoom-min="11">
        <line stroke="#9A9A9A" stroke-width="1.0" />
    </rule>
    <rule e="way" k="highway" v="tertiary|tertiary_link" zoom-min="10">
        <line stroke="#7A7A7A" stroke-width="1.2" />
    </rule>
    <rule e="way" k="highway" v="secondary|secondary_link" zoom-min="9">
        <line stroke="#C9A227" stroke-width="1.3" />
    </rule>
    <rule e="way" k="highway" v="primary|primary_link" zoom-min="8">
        <line stroke="#E09A1E" stroke-width="1.5" />
    </rule>
    <rule e="way" k="highway" v="trunk|trunk_link" zoom-min="7">
        <line stroke="#E07A1E" stroke-width="1.6" />
    </rule>
    <rule e="way" k="highway" v="motorway|motorway_link" zoom-min="6">
        <line stroke="#E0601E" stroke-width="1.8" />
    </rule>

    <!-- Cycling infrastructure — emphasised for a bike computer -->
    <rule e="way" k="highway" v="cycleway" zoom-min="11">
        <line stroke="#0077AA" stroke-width="1.1" />
    </rule>
    <rule e="way" k="cycleway" v="track|lane|opposite_track|opposite_lane" zoom-min="12">
        <line stroke="#0091B5" stroke-width="0.9" />
    </rule>
    <rule e="way" k="highway" v="path|footway|track|bridleway" zoom-min="12">
        <line stroke="#9C7A50" stroke-width="0.7" />
    </rule>

    <!-- Road name labels at high zoom -->
    <rule e="way" k="highway" v="motorway|trunk|primary|secondary|tertiary|residential" zoom-min="16">
        <caption k="name" font-style="bold" font-size="11" fill="#202020" stroke="#FFFFFF" stroke-width="2.0" />
    </rule>

    <!-- Place labels -->
    <rule e="node" k="place" v="city|town" zoom-min="9">
        <caption k="name" font-style="bold" font-size="13" fill="#1A1A1A" stroke="#FFFFFF" stroke-width="2.0" />
    </rule>
    <rule e="node" k="place" v="village|suburb" zoom-min="13">
        <caption k="name" font-size="11" fill="#333333" stroke="#FFFFFF" stroke-width="2.0" />
    </rule>
</rendertheme>
