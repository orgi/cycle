{
  "name": "cycle-flutter",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // Pass the host KVM device + group through so the Android emulator is
  // hardware-accelerated. Drop these if your host has no /dev/kvm.
  "runArgs": [
    "--device=/dev/kvm",
    "--group-add=kvm"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter"
      ],
      "settings": {
        "dart.flutterSdkPath": "/sdks/flutter"
      }
    }
  },
  "postCreateCommand": "flutter doctor -v && (flutter pub get || true)"
}
